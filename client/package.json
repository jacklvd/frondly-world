    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-transform-private-methods": "^7.29.7",
